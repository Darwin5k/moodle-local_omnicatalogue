{{!
    @template local_omnicatalogue/filter_sidebar
    A single filter facet accordion panel.
    Context: fieldid, fieldname, values[], hasactive
}}
<div class="local-omnicatalogue-facet mb-3 border rounded">
  <button class="btn btn-link w-100 text-start d-flex justify-content-between align-items-center p-3 text-decoration-none text-dark"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#facet-{{fieldid}}"
          aria-expanded="{{#hasactive}}true{{/hasactive}}{{^hasactive}}false{{/hasactive}}">
    <span class="fw-semibold">{{fieldname}}</span>
    {{#hasactive}}<span class="badge bg-primary rounded-pill">&#10003;</span>{{/hasactive}}
  </button>
  <div id="facet-{{fieldid}}" class="collapse{{#hasactive}} show{{/hasactive}}">
    <div class="px-3 pb-3" style="max-height: 260px; overflow-y: auto;">
      {{#values}}
        <div class="form-check">
          <input class="form-check-input"
                 type="checkbox"
                 name="f[{{filterid}}][]"
                 value="{{value}}"
                 id="facet-{{filterid}}-{{value}}"
                 {{#selected}}checked{{/selected}}>
          <label class="form-check-label d-flex justify-content-between" for="facet-{{filterid}}-{{value}}">
            <span>{{value}}</span>
            <span class="text-muted small">({{count}})</span>
          </label>
        </div>
      {{/values}}
    </div>
  </div>
</div>
