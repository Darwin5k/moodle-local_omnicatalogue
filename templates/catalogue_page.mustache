{{!
    @template local_omnicatalogue/catalogue_page
    Course catalogue page with filter sidebar and course grid.
}}
<div class="local-omnicatalogue container-fluid py-4">
  <div class="row">

    {{! Filter sidebar }}
    <div class="col-md-3 col-lg-2 mb-4">
      <form method="get" action="{{formaction}}">
        {{#filterparams}}
          <input type="hidden" name="{{name}}" value="{{value}}">
        {{/filterparams}}
        <input type="hidden" name="page" value="0">

        <div class="local-omnicatalogue-sidebar-box card">
          <div class="card-body p-3">
            <div class="d-flex align-items-baseline justify-content-between mb-2">
              <span class="local-omnicatalogue-sidebar__title">{{filterby}}</span>
              {{#hasfilters}}
                <a href="{{clearurl}}" class="local-omnicatalogue-sidebar__clear text-decoration-none small">{{clearfilters}}</a>
              {{/hasfilters}}
            </div>
            <hr class="mt-0 mb-3">

            {{#facets}}
              {{> local_omnicatalogue/filter_sidebar}}
            {{/facets}}

            {{#hasfacets}}
              <button type="submit" class="btn btn-primary btn-sm w-100 mt-2">{{applyfilters}}</button>
            {{/hasfacets}}
          </div>
        </div>
      </form>
    </div>

    {{! Course grid }}
    <div class="col-md-9 col-lg-10">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <span class="text-muted small">{{resultstring}}</span>
      </div>

      {{#nocourses}}
        <div class="alert alert-info">{{nocoursestr}}</div>
      {{/nocourses}}

      <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-4">
        {{#courses}}
          {{> local_omnicatalogue/course_card}}
        {{/courses}}
      </div>

      {{#haspages}}
        <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
          {{#hasprev}}
            <form method="get" action="{{formaction}}">
              {{#filterparams}}
                <input type="hidden" name="{{name}}" value="{{value}}">
              {{/filterparams}}
              <input type="hidden" name="page" value="{{prevpage}}">
              <button type="submit" class="btn btn-outline-primary btn-sm">&laquo; Previous</button>
            </form>
          {{/hasprev}}
          {{#hasnext}}
            <form method="get" action="{{formaction}}">
              {{#filterparams}}
                <input type="hidden" name="{{name}}" value="{{value}}">
              {{/filterparams}}
              <input type="hidden" name="page" value="{{nextpage}}">
              <button type="submit" class="btn btn-outline-primary btn-sm">Next &raquo;</button>
            </form>
          {{/hasnext}}
        </div>
      {{/haspages}}
    </div>

  </div>
</div>
