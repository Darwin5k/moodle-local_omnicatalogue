{{!
    @template local_omnicatalogue/course_card
    A single course card in the catalogue grid.
    Context: id, fullname, summary, category, courseurl, imageurl, fieldvalues[]
}}
<div class="col">
  <div class="card h-100 shadow-sm">
    <a href="{{courseurl}}" class="text-decoration-none">
      <img src="{{imageurl}}"
           class="card-img-top"
           alt=""
           style="height: 160px; object-fit: cover;">
    </a>
    <div class="card-body d-flex flex-column">
      <div class="text-muted small mb-1">{{category}}</div>
      <h6 class="card-title mb-2">
        <a href="{{courseurl}}" class="text-decoration-none text-dark stretched-link">{{fullname}}</a>
      </h6>
      {{#summary}}
        <p class="card-text text-muted small flex-grow-1">{{summary}}</p>
      {{/summary}}
      {{#hasfieldvalues}}
        <hr class="my-2">
        {{#fieldvalues}}
          <div class="small">
            <span class="fw-semibold">{{fieldname}}:</span> {{values}}
          </div>
        {{/fieldvalues}}
      {{/hasfieldvalues}}
    </div>
  </div>
</div>
