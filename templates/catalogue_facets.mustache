{{!
    @template local_omnicatalogue/catalogue_facets

    Renders all facet panels for the filter sidebar.
    Used by the AMD module to re-render just the facet list after a filter change.

    Context variables:
    * facets - array of facet objects, each passed to filter_sidebar.

    Example context (json):
    {
        "facets": [
            {
                "facetkey": "cf_1",
                "fieldname": "Subject Area",
                "hasactive": false,
                "values": [
                    {"value": "programming", "label": "Programming", "count": 5, "selected": false, "facetkey": "cf_1"},
                    {"value": "design", "label": "Design", "count": 3, "selected": false, "facetkey": "cf_1"}
                ]
            }
        ]
    }
}}
{{#facets}}
  {{> local_omnicatalogue/filter_sidebar}}
{{/facets}}
