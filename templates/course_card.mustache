{{!
    @template local_omnicatalogue/course_card

    A single course card in the catalogue grid.

    Context variables:
    * showimage       - bool: display course image.
    * showsummary     - bool: display course summary.
    * showcategory    - bool: display category name.
    * showcontacts    - bool: display course contacts.
    * showenroltype   - bool: display enrolment type badge.
    * showenrolstatus - bool: display enrolment status badge.
    * id              - int:    course ID.
    * fullname        - string: course full name.
    * summary         - string: plain-text summary excerpt.
    * category        - string: category name.
    * courseurl       - string: URL to the course page.
    * imageurl        - string: URL of the course overview image.
    * hasfieldvalues  - bool: whether any omniselect card fields have values.
    * fieldvalues     - array: [{fieldname, values}].
    * contacts        - string: comma-separated course contact names.
    * enroltype       - string: short enrolment method label.
    * completed       - bool: current user has completed this course.
    * enrolledonly    - bool: current user is enrolled but not yet completed.
    * hasbadges       - bool: whether any badge row should be shown.
}}
<div class="col">
  <div class="card h-100 shadow-sm">

    {{#showimage}}
      <a href="{{courseurl}}" class="text-decoration-none" tabindex="-1" aria-hidden="true">
        <img src="{{imageurl}}"
             class="card-img-top local-omnicatalogue-card-img"
             alt="">
      </a>
    {{/showimage}}

    <div class="card-body d-flex flex-column">

      {{#showcategory}}
        <div class="text-muted small mb-1">{{category}}</div>
      {{/showcategory}}

      <h6 class="card-title mb-2">
        <a href="{{courseurl}}"
           class="text-decoration-none text-dark stretched-link">{{fullname}}</a>
      </h6>

      {{! Badge row: enrolment status + enrolment type }}
      {{#hasbadges}}
        <div class="d-flex flex-wrap gap-1 mb-2">
          {{#completed}}
            <span class="badge text-bg-success local-omnicatalogue-badge--completed">{{#str}}completed, local_omnicatalogue{{/str}}</span>
          {{/completed}}
          {{#enrolledonly}}
            <span class="badge text-bg-info local-omnicatalogue-badge--enrolled">{{#str}}enrolled, local_omnicatalogue{{/str}}</span>
          {{/enrolledonly}}
          {{#showenroltype}}
            {{#enroltype}}
              <span class="badge local-omnicatalogue-badge--enroltype">{{enroltype}}</span>
            {{/enroltype}}
          {{/showenroltype}}
        </div>
      {{/hasbadges}}

      {{#showsummary}}
        {{#summary}}
          <p class="card-text text-muted small flex-grow-1">{{summary}}</p>
        {{/summary}}
      {{/showsummary}}

      {{#showcontacts}}
        {{#contacts}}
          <div class="local-omnicatalogue-contacts small text-muted mt-auto pt-2">
            <span class="local-omnicatalogue-contacts__icon" aria-hidden="true">&#128100;</span>
            {{contacts}}
          </div>
        {{/contacts}}
      {{/showcontacts}}

      {{#hasfieldvalues}}
        <hr class="my-2">
        {{#fieldvalues}}
          <div class="small">
            <span class="fw-semibold">{{fieldname}}:</span> {{values}}
          </div>
        {{/fieldvalues}}
      {{/hasfieldvalues}}

    </div>
  </div>
</div>
