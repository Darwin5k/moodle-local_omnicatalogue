<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/omnicatalogue/db" VERSION="20260515"
    COMMENT="XMLDB file for local_omnicatalogue"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_omnicatalogue_taggroups" COMMENT="Tag groups for the catalogue filter sidebar">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_omnicatalogue_tgroup_tags" COMMENT="Tags assigned to catalogue tag groups">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="tagid" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_groupid" TYPE="foreign" FIELDS="groupid"
             REFTABLE="local_omnicatalogue_taggroups" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="uniq_group_tag" UNIQUE="true" FIELDS="groupid, tagid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
