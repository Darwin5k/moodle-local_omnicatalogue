{{!
    @template local_omnicatalogue/catalogue_page

    Course catalogue page with filter sidebar and course grid.
    The AMD module targets elements by ID to update sections in place via AJAX.

    Context variables:
    * formaction   - URL for the filter form action.
    * filterby     - translated "Filter by" label.
    * clearfilters - translated "Clear filters" label.
    * clearurl     - URL that clears all filters (base catalogue URL).
    * hasfilters   - boolean; true when any filters are currently active.
    * hasfacets    - boolean; true when at least one facet panel exists.
    * applyfilters - translated "Apply filters" button label.
    * facets       - array of facet objects passed to catalogue_facets.
    * resultstring - translated result-count string.
    * courses      - array of course card objects (passed to catalogue_courses).
    * nocourses    - boolean; true when result set is empty.
    * nocoursestr  - translated "no courses" message.
    * haspages     - boolean; pagination needed.
    * hasprev / hasnext / prevpage / nextpage - pagination state.

    Example context (json):
    {
        "formaction": "http://example.com/local/omnicatalogue/",
        "filterby": "Filter by",
        "clearfilters": "Clear filters",
        "clearurl": "http://example.com/local/omnicatalogue/",
        "hasfilters": false,
        "hasfacets": true,
        "applyfilters": "Apply filters",
        "facets": [],
        "resultstring": "Showing 20 of 42 courses",
        "courses": [],
        "nocourses": false,
        "nocoursestr": "No courses found.",
        "haspages": false,
        "hasprev": false,
        "hasnext": false,
        "prevpage": 0,
        "nextpage": 1,
        "isediting": false,
        "settingsurl": "http://example.com/local/omnicatalogue/settings.php",
        "settingslabel": "Settings",
        "taggroupsurl": "http://example.com/local/omnicatalogue/taggroups.php",
        "taggroupslabel": "Tag groups"
    }
}}
{{! Admin bar — visible to managecatalogue users when Moodle edit mode is on. }}
{{#isediting}}
<div class="local-omnicatalogue-adminbar d-flex align-items-center justify-content-end gap-2 py-2 px-3 mb-2 border-bottom">
  <a href="{{settingsurl}}" class="btn btn-sm btn-outline-secondary">
    <span aria-hidden="true">&#9881;</span> {{settingslabel}}
  </a>
  <a href="{{taggroupsurl}}" class="btn btn-sm btn-outline-secondary">
    <span aria-hidden="true">&#127991;</span> {{taggroupslabel}}
  </a>
</div>
{{/isediting}}

<div class="local-omnicatalogue container-fluid py-4" id="omnicatalogue-root">
  <div class="row">

    {{! Filter sidebar — static wrapper; only the facet list inside is replaced }}
    <div class="col-md-3 col-lg-2 mb-4">
      <form method="get" action="{{formaction}}" id="omnicatalogue-filter-form">
        <input type="hidden" name="page" value="0">

        <div class="local-omnicatalogue-sidebar-box card">
          <div class="card-body p-3">

            <div class="d-flex align-items-baseline justify-content-between mb-2">
              <span class="local-omnicatalogue-sidebar__title">{{filterby}}</span>
              <a href="{{clearurl}}"
                 id="omnicatalogue-clear-link"
                 class="local-omnicatalogue-sidebar__clear text-decoration-none small{{^hasfilters}} d-none{{/hasfilters}}">
                {{clearfilters}}
              </a>
            </div>
            <hr class="mt-0 mb-3">

            {{! Facet panels — replaced by AJAX re-renders }}
            <div id="omnicatalogue-facets">
              {{> local_omnicatalogue/catalogue_facets}}
            </div>

            {{#hasfacets}}
              <button type="submit"
                      class="btn btn-primary btn-sm w-100 mt-2">{{applyfilters}}</button>
            {{/hasfacets}}

          </div>
        </div>
      </form>
    </div>

    {{! Course grid }}
    <div class="col-md-9 col-lg-10">

      <div class="d-flex align-items-center justify-content-between mb-3">
        <span class="text-muted small" id="omnicatalogue-resultcount">{{resultstring}}</span>
      </div>

      {{! Outer wrapper is position:relative so the loading overlay can sit on top }}
      <div class="position-relative">

        {{! Loading overlay — hidden by default; JS toggles d-none }}
        <div id="omnicatalogue-loading" class="local-omnicatalogue-loading d-none">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading&hellip;</span>
          </div>
        </div>

        {{! Course grid + pagination — replaced by AJAX re-renders }}
        <div id="omnicatalogue-courses-inner">
          {{> local_omnicatalogue/catalogue_courses}}
        </div>

      </div>
    </div>

  </div>
</div>
