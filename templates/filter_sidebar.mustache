{{!
    @template local_omnicatalogue/filter_sidebar

    A single filter facet panel (collapsible checkbox list).

    Context variables:
    * facetkey  - string key used for the collapse ID and checkbox names.
    * fieldname - human-readable facet label shown in the panel header.
    * hasactive - boolean; true when at least one value in this facet is selected.
    * values    - array of {value, label, count, selected, facetkey}.

    Example context (json):
    {
        "facetkey": "cf_1",
        "fieldname": "Subject Area",
        "hasactive": true,
        "values": [
            {"value": "programming", "label": "Programming", "count": 5, "selected": true, "facetkey": "cf_1"},
            {"value": "design", "label": "Design", "count": 3, "selected": false, "facetkey": "cf_1"},
            {"value": "business", "label": "Business", "count": 7, "selected": false, "facetkey": "cf_1"}
        ]
    }
}}
<div class="local-omnicatalogue-facet mb-1">
  <button class="local-omnicatalogue-facet__header w-100 text-start d-flex justify-content-between align-items-center py-2 px-0 bg-transparent border-0"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#facet-{{facetkey}}"
          aria-expanded="{{#hasactive}}true{{/hasactive}}{{^hasactive}}false{{/hasactive}}">
    <span class="d-flex align-items-center gap-2">
      <span class="local-omnicatalogue-caret{{#hasactive}} local-omnicatalogue-caret--active{{/hasactive}}"></span>
      <span class="small fw-semibold text-dark">{{fieldname}}</span>
    </span>
  </button>

  <div id="facet-{{facetkey}}" class="collapse{{#hasactive}} show{{/hasactive}}">
    <div class="local-omnicatalogue-facet__options pb-1" style="max-height: 240px; overflow-y: auto;">
      {{#values}}
        <label class="local-omnicatalogue-option d-flex align-items-center justify-content-between py-1 px-2 rounded{{#selected}} local-omnicatalogue-option--selected{{/selected}}">
          <span class="d-flex align-items-center gap-2">
            <input class="form-check-input flex-shrink-0 mt-0"
                   type="checkbox"
                   name="f[{{facetkey}}][]"
                   value="{{value}}"
                   {{#selected}}checked{{/selected}}>
            <span class="small">{{label}}</span>
          </span>
          <span class="badge rounded-pill local-omnicatalogue-count">{{count}}</span>
        </label>
      {{/values}}
    </div>
  </div>

  <hr class="my-2">
</div>
